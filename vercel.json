{
  "version": 2,
  "buildCommand": "echo 'Static site - no build needed'",
  "framework": null,
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, immutable"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/index.html",
      "dest": "/index.html",
      "methods": ["GET", "HEAD"]
    },
    {
      "src": "/order.html",
      "dest": "/order.html",
      "methods": ["GET", "HEAD"]
    },
    {
      "src": "/(.+)",
      "dest": "/$1"
    }
  ]
}
